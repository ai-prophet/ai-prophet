# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:port/dbname"

# ── Kalshi API (Haifeng) ──────────────────────────────────────────
KALSHI_API_KEY_ID=""
KALSHI_PRIVATE_KEY_B64=""
KALSHI_BASE_URL=https://api.elections.kalshi.com

# ── Kalshi API (Jibang) ───────────────────────────────────────────
KALSHI_API_KEY_ID_JIBANG=""
KALSHI_PRIVATE_KEY_B64_JIBANG=""

# ── Betting Control ───────────────────────────────────────────────
LIVE_BETTING_ENABLED=true
LIVE_BETTING_DRY_RUN=true

# ── Worker Settings ───────────────────────────────────────────────
WORKER_POLL_INTERVAL_SEC=3600
WORKER_MODELS="gemini:gemini-3.1-pro-preview"
WORKER_MODELS_HAIFENG="gemini:gemini-3.1-pro-preview"
WORKER_MODELS_JIBANG="gemini:gemini-3.1-pro-preview:market"
WORKER_SLUG=live_trading
WORKER_MAX_TICKS=9999
WORKER_STARTING_CASH=10000
WORKER_MAX_MARKETS=50
WORKER_MAX_ACTIVE_MARKETS=50
WORKER_STRATEGY=rebalancing
WORKER_STRATEGY_HAIFENG=rebalancing
WORKER_STRATEGY_JIBANG=rebalancing
MARKET_FETCHER_HAIFENG=true
MARKET_FETCHER_JIBANG=false
WORKER_PEER_INSTANCES_HAIFENG=Jibang
WORKER_PEER_INSTANCES_JIBANG=Haifeng

# ── Predictor Service (Cloud Run) ────────────────────────────────
PREDICTOR_SERVICE_URL=
PREDICTOR_API_KEY=

# ── Prophet Arena API ────────────────────────────────────────────
BASE_URL="https://api.prophetarena.co"

# ── LLM API Keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY_HAIFENG=""
GEMINI_API_KEY_JIBANG=""
XAI_API_KEY=""

# ── Dashboard ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_INSTANCE=haifeng
NEXT_PUBLIC_INSTANCE_CONFIG=[{"key":"haifeng","label":"Haifeng","apiUrl":"http://localhost:8000","instanceName":"Haifeng","description":""},{"key":"jibang","label":"Jibang","apiUrl":"http://localhost:8000","instanceName":"Jibang","description":""}]

# ── API Server ────────────────────────────────────────────────────
API_CORS_ORIGINS=http://localhost:3000
